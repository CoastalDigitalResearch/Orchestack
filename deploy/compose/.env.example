# Orchestack Development Environment Variables
# Copy this file to .env and fill in your API keys.

# NATS
NATS_URL=nats://nats:4222

# Postgres
DATABASE_URL=postgresql://orchestack:orchestack-dev@postgres:5432/orchestack

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=orchestack
MINIO_SECRET_KEY=orchestack-dev

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=orchestack-dev-token

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=orchestack

# Model Provider Keys (at least one required for agent responses)
OPENCODE_ZEN_API_KEY=sk-your-opencode-zen-key
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
